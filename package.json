{
  "workspaces": [
    "apps/*",
    "packages/*",
    "components/*",
    "ui-primitives/*"
  ],
  "name": "root",
  "private": true,
  "scripts": {
    "build": "turbo build --no-cache --force",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "sync-components": "rsync -av --delete ./components/src/ui/ ./apps/docs/components/ui/ && node ./scripts/process-imports.js",
    "release": "changeset publish",
    "cli": "pnpm --filter @pallas-ui/figma-cli cli"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "^2.29.6",
    "@pandacss/dev": "^1.9.1",
    "prettier": "^3.2.5",
    "turbo": "^2.3.3",
    "typescript": "5.5.4"
  },
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "react": "19.2.4",
      "react-dom": "19.2.4"
    }
  }
}